# Symlink or copy repo root `.env` here for `pnpm dev:frontend`.
# See root `.env.example` for DATABASE_URL, deploy keys, indexer tuning.
#
# WalletConnect / Reown
VITE_WALLETCONNECT_PROJECT_ID=
#
# Optional backend base URL (defaults in dev often assume localhost:3001)
# VITE_API_BASE=http://localhost:3001
#
# Canonical chain + contract addresses: shared/config/protocol.ts (@slabfinance/shared)
#
# Optional: max token id for ownerOf scan when the collection is not ERC721Enumerable (default 2000)
# VITE_EVM_LOCK_OWNER_SCAN_MAX=2000
