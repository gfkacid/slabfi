# Copy to repo root as `.env` (frontend can symlink: ln -s ../.env frontend/.env)
#
# Protocol defaults: shared/config/protocol.ts (also: pnpm print:deploy-env)

# Reown AppKit / WalletConnect (per-developer)
VITE_WALLETCONNECT_PROJECT_ID=

# Nest read API (card valuations, collateral, activity)
# VITE_API_BASE=http://localhost:3001

# Solana hub + indexer (optional overrides)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SLAB_HUB_PROGRAM_ID=

# EVM deploy / Foundry — never commit a real key
DEPLOYER_PRIVATE_KEY=

# Optional RPC overrides (indexer + scripts use these names)
# POLYGON_RPC_URL=
# BASE_RPC_URL=

# Solana hub admin (JSON array or path) — `pnpm whitelist:hub-evm` whitelists Courtyard/Beezie synthetic mints
# HUB_ADMIN_KEYPAIR=

# Signs `receive_cross_chain_lock` on Solana after EVM locks (same key may pay rent)
# ROUTER_AUTHORITY_KEYPAIR=

# Oracle pushes `oracle_set_price` after relay (6-decimal USDC → 8d on-chain in relayer)
# ORACLE_AUTHORITY_KEYPAIR=

# Relayer: set SOLANA_RELAYER_ENABLED=true to poll `AdapterLocked` events and submit hub txs
# SOLANA_RELAYER_ENABLED=false
# SOLANA_RELAYER_POLL_MS=15000
# ORACLE_FALLBACK_PRICE_USD8=1000000000

# Backend inventory API scan cap (ownerOf probe) when collection is not enumerable
# INVENTORY_OWNER_SCAN_MAX=2000

# Backend + indexer
DATABASE_URL=mysql://slab:slab@127.0.0.1:3306/slabfinance
PORT=3001

INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LOG_CHUNK_SIZE=2000

# PriceCharting subscription token (Prices API /api/product)
PRICECHARTING_API_KEY=
# Optional: `pnpm db:fetch:card-prices` — collection filter (lowercase 0x address)
# PRICE_FETCH_COLLECTION=
# PRICE_FETCH_DELAY_MS=250

# Backend GET /cards/:collection/:tokenId/price (x-api-key header)
SLABFI_API_KEY=

# Optional: seed Card rows from scripts/data/cardFi-collectibles-metadata.stub.json
# Must match the Polygon (or configured) ERC-721 used for catalog rows
# SEED_CARD_COLLECTION=0xYourCollectionOnPolygon
# PRICECHARTING_ID_1=12345
