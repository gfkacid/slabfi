# Copy to repo root as `.env` (frontend can symlink: ln -s ../.env frontend/.env)
#
# Chain RPCs, CCIP constants, and contract addresses live in shared/config/testnet.ts
# Hub deploy: `scripts/deploy-all.sh` exports HUB_USDC_ADDRESS from testnet.ts (hub.contracts.usdc).
# Optional seed liquidity (raw token units); default is 1_000 * 10**decimals when omitted.
# HUB_SEED_DEPOSIT_RAW=

# Reown AppKit / WalletConnect (per-developer)
VITE_WALLETCONNECT_PROJECT_ID=

# Nest read API (protocol stats, activity, collateral catalog, card valuations).
# Card deposit UI calls GET {VITE_API_BASE}/cards/{collection}/{tokenId}/valuation
# Default dev:
# VITE_API_BASE=http://localhost:3001

# Deploy scripts only — never commit a real key
DEPLOYER_PRIVATE_KEY=

# Optional: recipient for `pnpm mint:collectibles` when scripts/mint-cardfi-collectibles.ts MINT_RECIPIENT is null (default: deployer).
# MINT_RECIPIENT=

# Optional: override hub (Arc) / Sepolia RPC for forge, `pnpm mint:collectibles`, `pnpm ccip:fund-message-router`, etc.
# ARC_TESTNET_RPC=
# Arc — if `ccip:fund-message-router` txs never confirm, use legacy gas (same idea as ARC_CONFIGURE_LEGACY):
# ARC_FUND_CCIP_LEGACY=1
# ARC_FUND_CCIP_GAS_PRICE=120000000000
# Or raise EIP-1559 bump (percent, default 300 = 3×): ARC_FUND_GAS_BUMP_PERCENT=400
# Force EIP-1559 even when ARC_CONFIGURE_LEGACY=1: ARC_FUND_CCIP_EIP1559=1
# `ccip:fund-message-router` auto-clears mempool nonce backlog (0-value replace txs). Optional:
# ARC_FUND_CCIP_SKIP_UNSTICK=1
# ARC_FUND_CCIP_UNSTICK_GAS_PRICE=600000000000
# ARC_FUND_CCIP_UNSTICK_MAX_ROUNDS=25
# Optional: Arc HTTP timeout / receipt wait for `pnpm ccip:fund-message-router` (slow Arc finality)
# ARC_TESTNET_RPC_TIMEOUT_MS=120000
# Receipt poll for `ccip:fund-message-router` (default 15000 ms)
# CCIP_FUND_RECEIPT_TIMEOUT_MS=15000
# Optional: native USDC to CCIPMessageRouter, smallest units (6 decimals; default 1000000 = 1 USDC)
# CCIP_MESSAGE_ROUTER_FUND_VALUE=
# Permissionless CCIP execution on Arc (`pnpm ccip:manual-exec -- 0x<messageId>`) — optional if same as deployer
# CCIP_MANUAL_EXEC_PRIVATE_KEY=
# Optional gas override for manual execute receiver callback
# CCIP_MANUAL_EXEC_GAS_LIMIT=500000
# SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_TIMEOUT_MS=120000
# MINT_RECEIPT_TIMEOUT_MS=600000

# Sepolia: seed mints from stub JSON can use ~27M gas each; public RPCs often cap at ~16.7M. deploy-all.sh
# defaults SOURCE_DEPLOY_TOKEN_LIMIT to 0 (skip seed mints). Set higher to mint from stub when your RPC allows.
# SOURCE_DEPLOY_TOKEN_LIMIT=6

# Arc Phase 3 (Configure_Hub_Adapters): if you see replacement underpriced / EIP-1559 fee errors, try legacy gas:
# ARC_CONFIGURE_LEGACY=1
# ARC_CONFIGURE_GAS_PRICE=120000000000

# CRE platform API key — only needed for `cre workflow deploy` once CRE access is open (whitelisted orgs today).
# Local `cre workflow simulate --broadcast` does not use this. See SETUP.md §1b / §4.
# CRE_API_KEY=

# Optional overrides when using deploy-all.sh without pnpm setup:
# DEPLOY_CRE_WORKFLOW=1 runs local CRE simulate + on-chain setMockPrice (needs backend up for default price URL).
# EXTERNAL_PRICE_API_URL overrides default backend quote URL in deploy-all.sh (otherwise
# http://127.0.0.1:3001/cards/{collectible}/{CRE_PRICE_TOKEN_ID}/price).
# CRE_PRICE_TOKEN_ID=1

# Backend + indexer
DATABASE_URL=mysql://slab:slab@127.0.0.1:3306/slabfinance
PORT=3001

INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LOG_CHUNK_SIZE=2000

# PriceCharting subscription token (Prices API /api/product)
PRICECHARTING_API_KEY=
# Optional: `pnpm db:fetch:card-prices` — only cards in this collection (lowercase 0x address)
# PRICE_FETCH_COLLECTION=
# Optional: milliseconds between PriceCharting requests (rate limiting)
# PRICE_FETCH_DELAY_MS=250

# CRE → backend GET /cards/:collection/:tokenId/price (x-api-key header). Also used by deploy-all.sh for config.deploy.json.
SLABFI_API_KEY=

# Optional: seed Card rows from scripts/data/cardFi-collectibles-metadata.stub.json (token ids 1..N).
# If unset, pnpm db:seed:cards uses shared/config/testnet.ts → source.contracts.slabFinanceCollectible.
# SEED_CARD_COLLECTION=0xYourSepoliaCardFiCollectible
# PRICECHARTING_ID_1=12345
# After cards have pricechartingId set: pnpm db:fetch:card-prices (fills latestPriceUsdc + CardDailyPrice)
