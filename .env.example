# Copy to repo root as `.env` (frontend can symlink: ln -s ../.env frontend/.env)
#
# Chain RPCs, CCIP constants, and contract addresses live in shared/config/testnet.ts

# Reown AppKit / WalletConnect (per-developer)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: off-chain pricing API for card valuations in the deposit UI
# VITE_EXTERNAL_PRICE_API_BASE=https://api.example.com

# Nest read API (protocol stats, activity, indexed collateral). Default dev:
# VITE_API_BASE=http://localhost:3001

# Deploy scripts only — never commit a real key
DEPLOYER_PRIVATE_KEY=

# Optional: after hub + Sepolia deploy, generate cre/price-oracle/config.deploy.json and run
# `cre workflow deploy . --target arc-testnet-deploy --yes` (requires CRE CLI on PATH).
# DEPLOY_CRE_WORKFLOW=1
# CRE_API_KEY=
# EXTERNAL_PRICE_API_URL=https://api.example.com/v1/cards/1/quote
# CRE_PRICE_TOKEN_ID=1

# Backend + indexer
DATABASE_URL=mysql://slab:slab@127.0.0.1:3306/slabfinance
PORT=3001

INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LOG_CHUNK_SIZE=2000
