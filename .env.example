# Copy to frontend/.env for local dev (Vite reads env from frontend/ when running `pnpm dev:frontend` from repo root).
# You can also symlink: ln -s ../.env frontend/.env

# Reown AppKit / WalletConnect
VITE_WALLETCONNECT_PROJECT_ID=

# Hub network: "arc" (default) or "arbitrumSepolia"
VITE_HUB_NETWORK=arc

# Hub chain (Arc Testnet) — use when VITE_HUB_NETWORK=arc
VITE_ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Hub contracts (same env keys for either hub; set addresses from your hub deployment)
VITE_LENDING_POOL_ADDRESS=
VITE_COLLATERAL_REGISTRY_ADDRESS=
VITE_ORACLE_CONSUMER_ADDRESS=
VITE_HEALTH_FACTOR_ENGINE_ADDRESS=
VITE_LIQUIDATION_MANAGER_ADDRESS=
VITE_USDC_ADDRESS=

# Off-chain pricing API (optional; card valuations for deposit UI)
# VITE_EXTERNAL_PRICE_API_BASE=https://api.example.com

# Source chain (Ethereum Sepolia)
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_COLLATERAL_ADAPTER_ADDRESS=
VITE_SLAB_FINANCE_COLLECTIBLE_ADDRESS=

# Chainlink CCIP (reference / scripts)
VITE_CCIP_ROUTER_ARC=0xdE4E7FED43FAC37EB21aA0643d9852f75332eab8
VITE_CCIP_ROUTER_SEPOLIA=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
VITE_ARC_CHAIN_SELECTOR=3034092155422581607
VITE_SEPOLIA_CHAIN_SELECTOR=16015286601757825753

# Arbitrum Sepolia hub (when VITE_HUB_NETWORK=arbitrumSepolia)
# VITE_CCIP_ROUTER_ARBITRUM_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165
# VITE_ARBITRUM_SEPOLIA_CHAIN_SELECTOR=3478487238524512106

# Flare FDC (hackathon: use mock)
FLARE_FDC_VERIFICATION_ADDRESS=

# Deployment (scripts only)
DEPLOYER_PRIVATE_KEY=

# Hub RPC: Arc default; for Arbitrum Sepolia hub use https://sepolia-rollup.arbitrum.io/rpc
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
SEPOLIA_RPC=https://rpc.sepolia.org
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

CCIP_ROUTER_ARC=0xdE4E7FED43FAC37EB21aA0643d9852f75332eab8
# CCIP_ROUTER_HUB=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165

CCIP_ROUTER_SEPOLIA=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
CCIP_ROUTER_ARBITRUM_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165

ARC_CHAIN_SELECTOR=3034092155422581607
# When hub is Arc, source scripts use the same selector as the hub chain:
HUB_CHAIN_SELECTOR=3034092155422581607
# HUB_CHAIN_SELECTOR=3478487238524512106
SEPOLIA_CHAIN_SELECTOR=16015286601757825753
ARBITRUM_SEPOLIA_CHAIN_SELECTOR=3478487238524512106

# After hub deploy (manual or scripts/deploy-all.sh): CardFi CCIPMessageRouter on Arc
# HUB_CCIP_ROUTER_ADDRESS=

# Multi-chain deploy script (scripts/deploy-all.sh) — optional overrides
# HUB_DEPLOYMENT_OUTPUT=deployments/hub.json
# DEPLOYMENT_OUTPUT_FILE / SOURCE_NETWORK_NAME are set by the script per chain

# --- Backend + indexer (MySQL — run MySQL 8+ locally; no Docker Compose in-repo) ---
DATABASE_URL=mysql://slab:slab@127.0.0.1:3306/slabfinance

PORT=3001

INDEXER_HUB_RPC_URL=https://rpc.testnet.arc.network
INDEXER_SOURCE_RPC_URL=https://rpc.sepolia.org
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LOG_CHUNK_SIZE=2000

INDEXER_HUB_CHAIN_ID=5042002
INDEXER_SOURCE_CHAIN_ID=11155111

INDEXER_LENDING_POOL_ADDRESS=
INDEXER_COLLATERAL_REGISTRY_ADDRESS=
INDEXER_LIQUIDATION_MANAGER_ADDRESS=
INDEXER_ORACLE_CONSUMER_ADDRESS=
INDEXER_HEALTH_FACTOR_ENGINE_ADDRESS=
INDEXER_NFT_VAULT_ADDRESS=
INDEXER_COLLATERAL_ADAPTER_ADDRESS=

INDEXER_SLAB_COLLECTIBLE_ADDRESS=

BACKEND_HUB_RPC_URL=
BACKEND_HUB_CHAIN_ID=
BACKEND_LENDING_POOL_ADDRESS=
BACKEND_COLLATERAL_REGISTRY_ADDRESS=
BACKEND_HEALTH_FACTOR_ENGINE_ADDRESS=
