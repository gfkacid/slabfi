# Copy to repo root as `.env` (frontend can symlink: ln -s ../.env frontend/.env)
#
# Chain RPCs, CCIP constants, and contract addresses live in shared/config/testnet.ts
# Hub deploy: `scripts/deploy-all.sh` exports HUB_USDC_ADDRESS from testnet.ts (hub.contracts.usdc).
# Optional seed liquidity (raw token units); default is 1_000 * 10**decimals when omitted.
# HUB_SEED_DEPOSIT_RAW=

# Reown AppKit / WalletConnect (per-developer)
VITE_WALLETCONNECT_PROJECT_ID=

# Nest read API (protocol stats, activity, collateral catalog, card valuations).
# Card deposit UI calls GET {VITE_API_BASE}/cards/{collection}/{tokenId}/valuation
# Default dev:
# VITE_API_BASE=http://localhost:3001

# Deploy scripts only — never commit a real key
DEPLOYER_PRIVATE_KEY=

# Optional: override hub/source RPC for forge if the public endpoint errors (e.g. txpool full -32003).
# ARC_TESTNET_RPC=
# SEPOLIA_RPC=

# CRE platform API key — only needed for `cre workflow deploy` once CRE access is open (whitelisted orgs today).
# Local `cre workflow simulate --broadcast` does not use this. See SETUP.md §1b / §4.
# CRE_API_KEY=

# Optional overrides when using deploy-all.sh without pnpm setup:
# DEPLOY_CRE_WORKFLOW=1 runs local CRE simulate + on-chain setMockPrice (needs backend up for default price URL).
# EXTERNAL_PRICE_API_URL overrides default backend quote URL in deploy-all.sh (otherwise
# http://127.0.0.1:3001/cards/{collectible}/{CRE_PRICE_TOKEN_ID}/price).
# CRE_PRICE_TOKEN_ID=1

# Backend + indexer
DATABASE_URL=mysql://slab:slab@127.0.0.1:3306/slabfinance
PORT=3001

INDEXER_POLL_INTERVAL_MS=5000
INDEXER_LOG_CHUNK_SIZE=2000

# PriceCharting subscription token (Prices API /api/product)
PRICECHARTING_API_KEY=

# CRE → backend GET /cards/:collection/:tokenId/price (x-api-key header). Also used by deploy-all.sh for config.deploy.json.
SLABFI_API_KEY=

# Optional: seed Card rows from scripts/data/cardFi-collectibles-metadata.stub.json (token ids 1..N)
# SEED_CARD_COLLECTION=0xYourSepoliaCardFiCollectible
# PRICECHARTING_ID_1=12345
