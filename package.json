{
  "name": "slab-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "pnpm --parallel --filter @slabfinance/frontend --filter @slabfinance/backend dev",
    "dev:frontend": "pnpm --filter @slabfinance/frontend dev",
    "dev:backend": "pnpm --filter @slabfinance/backend dev",
    "dev:indexer": "pnpm --filter @slabfinance/indexer dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "pnpm --filter @slabfinance/shared build && prisma generate && pnpm --filter @slabfinance/backend build && pnpm --filter @slabfinance/indexer build && pnpm --filter @slabfinance/frontend build",
    "build:shared": "pnpm --filter @slabfinance/shared build",
    "lint": "pnpm -r lint",
    "mint:collectibles": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/mint-cardfi-collectibles.ts",
    "db:seed:cards": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/seed-cards-from-stub.ts",
    "db:seed:indexer-cursors": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/seed-indexer-cursors.ts",
    "db:fetch:card-prices": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/fetch-card-prices-from-pricecharting.ts",
    "ccip:fund-message-router": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/fund-ccip-message-router.ts",
    "diagnose:collateral": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/diagnose-collateral-hub.ts",
    "diagnose:ccip": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/diagnose-ccip-message.ts",
    "ccip:manual-exec": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/ccip-manual-execute.ts",
    "oracle:push-mock": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/push-oracle-mock-from-catalog.ts",
    "oracle:reseed-pending": "pnpm --filter @slabfinance/indexer exec tsx ../scripts/reseed-pending-collateral-oracle.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "@chainlink/ccip-sdk": "1.4.1",
    "@chainlink/contracts": "^1.5.0",
    "@chainlink/contracts-ccip": "^1.6.0",
    "prisma": "6.19.3",
    "typescript": "^5.6.0"
  }
}
